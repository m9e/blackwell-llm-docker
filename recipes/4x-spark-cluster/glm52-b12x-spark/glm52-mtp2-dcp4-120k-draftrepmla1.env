# Known-good GLM-5.2 capacity configuration on 4x DGX Spark.
# Validated 2026-06-25 with:
# - model: /var/tmp/models/Mapika/GLM-5.2-NVFP4-MTP-hybrid
# - image: glm-darkdevotion-b12x:20260624-arm64-mtpfix6
# - capacity run: /tmp/glm52-kv-capacity-20260625-025728
# - robust guard/perf run: served as glm52-mtp3-dcp4-128k-util916 on 2026-06-25
# - trim-hook restore run: served as glm52-mtp3-dcp4-128k on 2026-06-25
# - result: READY, GPU KV cache size 132,096 tokens for max_model_len 131,072.
# - keep MAX_NUM_BATCHED_TOKENS=1024; 2048 fit but was slower in a 512-token decode probe.

IMAGE=glm-darkdevotion-b12x:20260626-arm64-draftrepmla3
MODEL_DIR=/var/tmp/models/Mapika/GLM-5.2-NVFP4-MTP-hybrid

PROFILE=custom
SERVED_MODEL_NAME=glm52-mtp2-dcp4-120k-draftrepmla1
TP_SIZE=4
PP_SIZE=1
DCP_SIZE=4
DCP_COMM_BACKEND=ag_rs
DCP_KV_CACHE_INTERLEAVE_SIZE=1

MAX_MODEL_LEN=122880
MAX_NUM_SEQS=1
MAX_NUM_BATCHED_TOKENS=1024
MAX_CUDAGRAPH_CAPTURE_SIZE=4
GPU_MEMORY_UTILIZATION=0.915
KV_CACHE_MEMORY_BYTES=1800000000
KV_CACHE_DTYPE=fp8
ENFORCE_EAGER=0

ENABLE_MTP=1
NUM_SPECULATIVE_TOKENS=2
ATTENTION_BACKEND=B12X_MLA_SPARSE
MOE_BACKEND=flashinfer_cutlass

VLLM_DCP_GLOBAL_TOPK=1
VLLM_DCP_SHARD_DRAFT=0
VLLM_KZ_TRIM_AFTER_LOAD=1
VLLM_MTP_RECOMPUTE_TOPK_FROM_STEP=1
NCCL_IB_DISABLE=0
NCCL_SOCKET_IFNAME=enP2p1s0f0np0

# Keep B12X MoE/GEMM disabled until separately validated for Spark memory/perf.
VLLM_USE_B12X_MOE=0
VLLM_USE_B12X_FP8_GEMM=0
B12X_MOE_FORCE_A16=0
B12X_W4A16_TC_DECODE=0
KZ_KV_DIAG=1
