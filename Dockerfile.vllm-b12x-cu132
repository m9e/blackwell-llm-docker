# syntax=docker/dockerfile:1.7
# =============================================================================
# Clean vLLM+B12X image for Blackwell on CUDA 13.2.
#
# Source stack:
#   NVIDIA CUDA 13.2.1 cuDNN devel base
#   Latest CUDA 13.2-compatible NVIDIA library overlays: cuBLAS 13.4.1, cuDNN 9.22
#   PyTorch 2.12.0+cu132 from the official PyTorch wheel index
#   Patched NCCL 2.30.4 from local-inference-lab/nccl-canonical
#   FlashInfer from pinned upstream git
#   B12X from pinned git
#   vLLM from pinned git
#
# Build:
#   DOCKER_BUILDKIT=1 docker build \
#     -f Dockerfile.vllm-b12x-cu132 \
#     -t voipmonitor/vllm:vllm-b12x-cu132 .
# =============================================================================

ARG CUDA_VERSION=13.2.1
ARG UBUNTU_VERSION=24.04
ARG PYTHON_VERSION=3.12
ARG CUBLAS_CUDA13_VERSION=13.4.1.2-1
ARG CUDNN_CUDA13_VERSION=9.22.0.52-1
ARG CUDA_COMPAT_13_2_VERSION=595.71.05-1ubuntu1
ARG VLLM_B12X_CU132_SYSTEM_BASE_IMAGE=vllm-b12x-cu132-system-base-build
ARG VLLM_B12X_CU132_BUILD_BASE_IMAGE=vllm-b12x-cu132-build-base-build

ARG NCCL_REPO=https://github.com/local-inference-lab/nccl-canonical.git
ARG NCCL_REF=canonical/cu132-nccl2304-amd-noxml
ARG NCCL_COMMIT=dfab7c1ace32da250ba97757879429c341b7bcf9
ARG NCCL_SONAME=libnccl.so.2.30.4

ARG FLASHINFER_REPO=https://github.com/flashinfer-ai/flashinfer.git
ARG FLASHINFER_REF=refs/pull/3395/head
ARG FLASHINFER_COMMIT=9035311e975a6aeb2d229f5162e999dfb7c9a733

ARG DEEPGEMM_REPO=https://github.com/deepseek-ai/DeepGEMM.git
ARG DEEPGEMM_REF=refs/pull/324/head
ARG DEEPGEMM_COMMIT=

ARG B12X_REPO=https://github.com/lukealonso/b12x.git
ARG B12X_REF=refs/pull/11/head
ARG B12X_COMMIT=c929144c7689668b07ca65af10ceadf1c745165d

ARG VLLM_REPO=https://github.com/local-inference-lab/vllm.git
ARG VLLM_REF=dev/black-benediction
ARG VLLM_COMMIT=
ARG VLLM_BUILD_VERSION=0.11.2.dev279+black.benediction.b12x.cu132
ARG LAUNCHER_REPO=https://github.com/local-inference-lab/vllm.git
ARG LAUNCHER_REF=dev/black-benediction
ARG LAUNCHER_COMMIT=

ARG CUTLASS_REPO=https://github.com/NVIDIA/cutlass.git
ARG CUTLASS_REF=main
ARG CUTLASS_COMMIT=982cb9e718bcd4d7ac546b1795702a08326dfe4b

ARG TRITON_KERNELS_REPO=https://github.com/triton-lang/triton.git
ARG TRITON_KERNELS_REF=
ARG TRITON_KERNELS_COMMIT=

ARG MAX_JOBS=128
ARG NVCC_THREADS=1
ARG VLLM_MAX_JOBS=128
ARG VLLM_NVCC_THREADS=1

# =============================================================================
# Stage 0: patched NCCL
# =============================================================================
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu${UBUNTU_VERSION} AS nccl-build

ARG NCCL_REPO
ARG NCCL_REF
ARG NCCL_COMMIT
ARG DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-euxo", "pipefail", "-c"]

RUN for attempt in {1..5}; do \
      if apt-get update; then break; fi; \
      if [[ "${attempt}" == "5" ]]; then exit 1; fi; \
      rm -rf /var/lib/apt/lists/*; \
      sleep $((attempt * 10)); \
    done \
    && apt-get install -y --no-install-recommends \
    git \
    python3 \
    build-essential \
    make \
    g++ \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
RUN git clone "${NCCL_REPO}" nccl \
 && cd nccl \
 && git checkout "${NCCL_REF}" \
 && if [[ -n "${NCCL_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${NCCL_COMMIT}"; fi \
 && make -j"$(nproc)" src.build CUDA_HOME=/usr/local/cuda \
 && strings "build/lib/libnccl.so.2.30.4" | grep -F "NCCL version 2.30.4 compiled with CUDA 13.2"

# =============================================================================
# Stage 1: reusable CUDA/Python/NCCL system base
# =============================================================================
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu${UBUNTU_VERSION} AS vllm-b12x-cu132-system-base-build

ARG PYTHON_VERSION
ARG NCCL_SONAME
ARG CUBLAS_CUDA13_VERSION
ARG CUDNN_CUDA13_VERSION
ARG CUDA_COMPAT_13_2_VERSION
ARG DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-euxo", "pipefail", "-c"]

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Keep the toolkit on 13.2.1, but overlay the latest CUDA 13 libraries NVIDIA
# publishes for Ubuntu 24.04 without pulling CUDA 13.3 packages.
RUN for attempt in {1..5}; do \
      if apt-get update; then break; fi; \
      if [[ "${attempt}" == "5" ]]; then exit 1; fi; \
      rm -rf /var/lib/apt/lists/*; \
      sleep $((attempt * 10)); \
    done \
    && apt-get install -y --allow-change-held-packages --no-install-recommends \
    python${PYTHON_VERSION} \
    python${PYTHON_VERSION}-dev \
    python${PYTHON_VERSION}-venv \
    python3-pip \
    git \
    git-lfs \
    wget \
    curl \
    ca-certificates \
    build-essential \
    cmake \
    ninja-build \
    ccache \
    pkg-config \
    patchelf \
    libssl-dev \
    libffi-dev \
    libjpeg-dev \
    libpng-dev \
    libgomp1 \
    numactl \
    libnuma-dev \
    libibverbs-dev \
    pciutils \
    cuda-compat-13-2=${CUDA_COMPAT_13_2_VERSION} \
    libcublas13-cuda-13=${CUBLAS_CUDA13_VERSION} \
    libcublas13-dev-cuda-13=${CUBLAS_CUDA13_VERSION} \
    cublas-cuda-13=${CUBLAS_CUDA13_VERSION} \
    libcudnn9-cuda-13=${CUDNN_CUDA13_VERSION} \
    libcudnn9-dev-cuda-13=${CUDNN_CUDA13_VERSION} \
    libcudnn9-headers-cuda-13=${CUDNN_CUDA13_VERSION} \
    libcudnn9-static-cuda-13=${CUDNN_CUDA13_VERSION} \
    && ldconfig \
    && rm -rf /var/lib/apt/lists/*

RUN cublas="$(readlink -f /usr/lib/x86_64-linux-gnu/libcublas/13/libcublas.so.13)" \
 && cublas_lt="$(readlink -f /usr/lib/x86_64-linux-gnu/libcublas/13/libcublasLt.so.13)" \
 && cublas_name="$(basename "${cublas}")" \
 && cublas_lt_name="$(basename "${cublas_lt}")" \
 && test -f "${cublas}" \
 && test -f "${cublas_lt}" \
 && for cuda_libdir in /usr/local/cuda/targets/x86_64-linux/lib /usr/local/cuda-${CUDA_VERSION}/targets/x86_64-linux/lib; do \
      if [[ -d "${cuda_libdir}" ]]; then \
        cuda_libdir="$(readlink -f "${cuda_libdir}")"; \
        rm -f "${cuda_libdir}"/libcublas.so "${cuda_libdir}"/libcublas.so.13 "${cuda_libdir}"/libcublas.so.13.*; \
        rm -f "${cuda_libdir}"/libcublasLt.so "${cuda_libdir}"/libcublasLt.so.13 "${cuda_libdir}"/libcublasLt.so.13.*; \
        ln -s "${cublas}" "${cuda_libdir}/${cublas_name}"; \
        ln -s "${cublas_name}" "${cuda_libdir}/libcublas.so.13"; \
        ln -s libcublas.so.13 "${cuda_libdir}/libcublas.so"; \
        ln -s "${cublas_lt}" "${cuda_libdir}/${cublas_lt_name}"; \
        ln -s "${cublas_lt_name}" "${cuda_libdir}/libcublasLt.so.13"; \
        ln -s libcublasLt.so.13 "${cuda_libdir}/libcublasLt.so"; \
      fi; \
    done \
 && ldconfig

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python${PYTHON_VERSION} 1 \
 && update-alternatives --install /usr/bin/python python /usr/bin/python${PYTHON_VERSION} 1

COPY --from=nccl-build /build/nccl/build/lib/${NCCL_SONAME} /opt/libnccl-local-inference.so.2.30.4

ENV NCCL_LOCAL_INFERENCE_PATH=/opt/libnccl-local-inference.so.2.30.4 \
    NCCL_PR2127_PATH=/opt/libnccl-local-inference.so.2.30.4 \
    VLLM_NCCL_SO_PATH=/opt/libnccl-local-inference.so.2.30.4

LABEL org.opencontainers.image.description="Reusable CUDA 13.2.1 vLLM+B12X system base with latest CUDA 13.2-compatible cuBLAS/cuDNN overlays and patched NCCL 2.30.4" \
      local-inference.cuda.version="13.2.1" \
      local-inference.cuda.compat.version="${CUDA_COMPAT_13_2_VERSION}" \
      local-inference.cublas.version="${CUBLAS_CUDA13_VERSION}" \
      local-inference.cudnn.version="${CUDNN_CUDA13_VERSION}" \
      local-inference.nccl.repo="local-inference-lab/nccl-canonical" \
      local-inference.nccl.branch="canonical/cu132-nccl2304-amd-noxml" \
      local-inference.nccl.version="2.30.4"

# =============================================================================
# Stage 1b: reusable PyTorch/CUTLASS build base
# =============================================================================
FROM ${VLLM_B12X_CU132_SYSTEM_BASE_IMAGE} AS vllm-b12x-cu132-build-base-build

SHELL ["/bin/bash", "-euxo", "pipefail", "-c"]

RUN python -m venv /opt/venv

ENV VIRTUAL_ENV=/opt/venv \
    PATH="/opt/venv/bin:${PATH}"

RUN --mount=type=cache,target=/root/.cache/pip \
    python -m pip install --upgrade "pip<26" setuptools wheel \
 && python -m pip install \
      --index-url https://download.pytorch.org/whl/cu132 \
      --extra-index-url https://pypi.org/simple \
      "torch==2.12.0+cu132" \
      "torchvision==0.27.0+cu132" \
 && python -m pip install \
      cuda-tile==1.3.0 \
      "nvidia-cutlass-dsl[cu13]==4.5.2" \
 && python -m pip install --force-reinstall --no-deps \
      nvidia-cutlass-dsl-libs-cu13==4.5.2 \
 && python -m pip check \
 && python - <<'PY'
import torch
print("torch", torch.__version__)
print("torch cuda", torch.version.cuda)
print("torch nccl", torch.cuda.nccl.version())
assert torch.__version__.startswith("2.12.0+cu132")
assert torch.version.cuda == "13.2"
PY

ENV CCACHE_DIR=/root/.ccache \
    CMAKE_C_COMPILER_LAUNCHER=ccache \
    CMAKE_CXX_COMPILER_LAUNCHER=ccache \
    CMAKE_CUDA_COMPILER_LAUNCHER=ccache \
    TORCH_CUDA_ARCH_LIST=12.0a \
    CMAKE_CUDA_ARCHITECTURES=120a \
    FLASHINFER_CUDA_ARCH_LIST=12.0f \
    FLASHINFER_LOCAL_VERSION=cu132 \
    FLASHINFER_NVCC_THREADS=1 \
    FLASHINFER_DISABLE_VERSION_CHECK=1 \
    AOT_MAX_JOBS_CAP=8

LABEL org.opencontainers.image.description="Reusable CUDA 13.2.1 vLLM+B12X build base with PyTorch 2.12 cu132 and CUTLASS DSL" \
      local-inference.torch.version="2.12.0+cu132" \
      local-inference.cutlass_dsl.version="4.5.2"

# =============================================================================
# Stage 1c: build settings overlay
# =============================================================================
FROM ${VLLM_B12X_CU132_BUILD_BASE_IMAGE} AS base

ARG MAX_JOBS
ARG NVCC_THREADS

SHELL ["/bin/bash", "-euxo", "pipefail", "-c"]

ENV MAX_JOBS=${MAX_JOBS} \
    NVCC_THREADS=${NVCC_THREADS}

# CUDA 13.x headers can be laid out under cccl/. Keep both old and new include
# paths usable for third-party build scripts.
RUN if [[ -d /usr/local/cuda/targets/x86_64-linux/include/cccl/cuda && ! -e /usr/local/cuda/include/cuda ]]; then \
      ln -sf /usr/local/cuda/targets/x86_64-linux/include/cccl/cuda /usr/local/cuda/include/cuda; \
    fi

# =============================================================================
# Stage 2a: build FlashInfer and flashinfer-cubin.
#
# Keep this stage independent from vLLM args so local BuildKit cache reuses the
# expensive FlashInfer/CUBIN build until CUDA/Torch/CUTLASS/FlashInfer changes.
# =============================================================================
FROM base AS flashinfer-build

ARG FLASHINFER_REPO
ARG FLASHINFER_REF
ARG FLASHINFER_COMMIT
ARG CUTLASS_REPO
ARG CUTLASS_REF
ARG CUTLASS_COMMIT

WORKDIR /build

RUN if [[ "${CUTLASS_REF}" =~ ^[0-9a-f]{40}$ ]]; then \
      git clone --filter=blob:none "${CUTLASS_REPO}" /build/cutlass; \
      cd /build/cutlass; \
      git checkout "${CUTLASS_REF}"; \
    else \
      git clone --depth 1 --branch "${CUTLASS_REF}" "${CUTLASS_REPO}" /build/cutlass; \
      cd /build/cutlass; \
    fi \
 && if [[ -n "${CUTLASS_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${CUTLASS_COMMIT}"; fi \
 && grep "CUTLASS_MAJOR\\|CUTLASS_MINOR\\|CUTLASS_PATCH" include/cutlass/version.h | head -3

RUN CUTLASS_DSL="$(python -c 'import cutlass.utils.blockscaled_layout as m; print(m.__file__)')" \
 && cp /build/cutlass/python/CuTeDSL/cutlass/utils/blockscaled_layout.py "${CUTLASS_DSL}" \
 && python -c 'from cutlass.utils.blockscaled_layout import sm120_make_smem_layout_sfa; print("OK: sm120_make_smem_layout_sfa available")'

RUN --mount=type=cache,target=/root/.cache/pip \
    python -m pip install \
      "apache-tvm-ffi>=0.1.6" \
      "nvidia-cudnn-frontend>=1.13.0" \
      packaging \
      pynvml \
      nvidia-ml-py \
      requests \
      numpy \
      einops \
      click \
      tabulate \
      tqdm

RUN --mount=type=cache,target=/root/.ccache \
    git clone --recursive "${FLASHINFER_REPO}" /tmp/flashinfer-src \
 && cd /tmp/flashinfer-src \
 && if [[ "${FLASHINFER_REF}" == refs/* ]]; then \
      git fetch origin "${FLASHINFER_REF}"; \
      git checkout FETCH_HEAD; \
    else \
      git checkout "${FLASHINFER_REF}"; \
    fi \
 && if [[ -n "${FLASHINFER_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${FLASHINFER_COMMIT}"; fi \
 && git submodule update --init --recursive \
 && python -m pip uninstall -y flashinfer-python flashinfer-cubin flashinfer-jit-cache || true \
 && FLASHINFER_CUDA_ARCH_LIST="${FLASHINFER_CUDA_ARCH_LIST}" \
    FLASHINFER_ENABLE_SM90=0 \
    MAX_JOBS="${MAX_JOBS}" \
    python -m pip install --no-build-isolation --no-deps -v . \
 && FLASHINFER_CUDA_ARCH_LIST="${FLASHINFER_CUDA_ARCH_LIST}" \
    MAX_JOBS="${MAX_JOBS}" \
    python -m pip wheel --no-build-isolation --no-deps -w /tmp/flashinfer-wheels ./flashinfer-cubin \
 && python -m pip install --no-deps --force-reinstall /tmp/flashinfer-wheels/flashinfer_cubin-*.whl \
 && FLASHINFER_CUDA_ARCH_LIST="${FLASHINFER_CUDA_ARCH_LIST}" \
    MAX_JOBS="${MAX_JOBS}" \
    python -m pip wheel --no-build-isolation --no-deps -w /tmp/flashinfer-wheels ./flashinfer-jit-cache \
 && python -m pip install --no-deps --force-reinstall /tmp/flashinfer-wheels/flashinfer_jit_cache-*.whl \
 && python - <<'PY'
import flashinfer
print("flashinfer", getattr(flashinfer, "__version__", "unknown"))
PY

# =============================================================================
# Stage 2b: build DeepGEMM on top of the cached FlashInfer stage.
# =============================================================================
FROM flashinfer-build AS deepgemm-build

ARG DEEPGEMM_REPO
ARG DEEPGEMM_REF
ARG DEEPGEMM_COMMIT

RUN --mount=type=cache,target=/root/.ccache \
    git clone --recursive "${DEEPGEMM_REPO}" /tmp/deepgemm-src \
 && cd /tmp/deepgemm-src \
 && if [[ "${DEEPGEMM_REF}" == refs/* ]]; then \
      git fetch origin "${DEEPGEMM_REF}"; \
      git checkout FETCH_HEAD; \
    else \
      git checkout "${DEEPGEMM_REF}"; \
    fi \
 && if [[ -n "${DEEPGEMM_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${DEEPGEMM_COMMIT}"; fi \
 && git submodule update --init --recursive \
 && DG_FORCE_BUILD=1 DG_USE_LOCAL_VERSION=1 \
    python -m pip install --no-build-isolation --no-deps --force-reinstall . \
 && cd / \
 && python -c 'import importlib.metadata as md; import deep_gemm; print("deep_gemm", getattr(deep_gemm, "__version__", md.version("deep_gemm")))' \
 && rm -rf /tmp/deepgemm-src

# =============================================================================
# Stage 2c: build B12X on top of cached FlashInfer/DeepGEMM.
# =============================================================================
FROM deepgemm-build AS b12x-build

ARG B12X_REPO
ARG B12X_REF
ARG B12X_COMMIT

RUN git clone --filter=blob:none "${B12X_REPO}" /tmp/b12x-src \
 && cd /tmp/b12x-src \
 && if [[ "${B12X_REF}" == refs/* ]]; then \
      git fetch origin "${B12X_REF}"; \
      git checkout FETCH_HEAD; \
    else \
      git checkout "${B12X_REF}"; \
    fi \
 && if [[ -n "${B12X_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${B12X_COMMIT}"; fi \
 && python -m pip install --no-deps --force-reinstall . \
 && rm -rf /tmp/b12x-src

# =============================================================================
# Stage 2d: build vLLM on top of cached FlashInfer/DeepGEMM/B12X.
# =============================================================================
FROM b12x-build AS vllm-build

ARG VLLM_REPO
ARG VLLM_REF
ARG VLLM_COMMIT
ARG VLLM_BUILD_VERSION
ARG LAUNCHER_REPO
ARG LAUNCHER_REF
ARG LAUNCHER_COMMIT
ARG VLLM_MAX_JOBS
ARG VLLM_NVCC_THREADS
ARG TRITON_KERNELS_REPO
ARG TRITON_KERNELS_REF
ARG TRITON_KERNELS_COMMIT

WORKDIR /build

RUN git clone --recursive --filter=blob:none "${VLLM_REPO}" /opt/vllm \
 && cd /opt/vllm \
 && git checkout "${VLLM_REF}" \
 && if [[ -n "${VLLM_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${VLLM_COMMIT}"; fi \
 && grep -v '^torch==' requirements/build/cuda.txt > /tmp/vllm-build-notorch.txt \
 && python -m pip install -r /tmp/vllm-build-notorch.txt \
 && python -m pip install -r requirements/common.txt \
 && python -m pip install setuptools_scm \
 && python -m pip check || true

WORKDIR /opt/vllm

RUN if [[ -f use_existing_torch.py ]]; then python use_existing_torch.py; fi

RUN if [[ -n "${TRITON_KERNELS_REF}" ]]; then \
      git clone --filter=blob:none "${TRITON_KERNELS_REPO}" /build/triton; \
      cd /build/triton; \
      git checkout "${TRITON_KERNELS_REF}"; \
      if [[ -n "${TRITON_KERNELS_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${TRITON_KERNELS_COMMIT}"; fi; \
      test -d /build/triton/python/triton_kernels/triton_kernels; \
    fi

RUN --mount=type=cache,target=/root/.ccache \
    export VLLM_VERSION_OVERRIDE="${VLLM_BUILD_VERSION}"; \
    export VLLM_TARGET_DEVICE=cuda; \
    export VLLM_USE_PRECOMPILED=0; \
    export VLLM_CUTLASS_SRC_DIR=/build/cutlass; \
    export MAX_JOBS="${VLLM_MAX_JOBS}"; \
    export CMAKE_BUILD_PARALLEL_LEVEL="${VLLM_MAX_JOBS}"; \
    export NVCC_THREADS="${VLLM_NVCC_THREADS}"; \
    if [[ -n "${TRITON_KERNELS_REF}" ]]; then \
      export TRITON_KERNELS_SRC_DIR=/build/triton/python/triton_kernels/triton_kernels; \
    fi; \
    python -m pip install --no-build-isolation --no-deps --force-reinstall . \
 && site_packages="$(python -c 'import site; print(site.getsitepackages()[0])')" \
 && if [[ -d "${site_packages}/vllm/third_party/triton_kernels" && ! -e "${site_packages}/triton_kernels" ]]; then \
      ln -s vllm/third_party/triton_kernels "${site_packages}/triton_kernels"; \
    fi \
 && for so in \
      /opt/venv/lib/python3.12/site-packages/vllm/_C.abi3.so \
      /opt/venv/lib/python3.12/site-packages/vllm/_C_stable_libtorch.abi3.so \
      /opt/venv/lib/python3.12/site-packages/vllm/cumem_allocator.abi3.so; do \
      if [[ -f "${so}" ]] && ! readelf -d "${so}" | grep -Fq 'libcuda.so.1'; then \
        patchelf --add-needed libcuda.so.1 "${so}"; \
      fi; \
    done \
 && TRITON_KERNELS_REF="${TRITON_KERNELS_REF}" python - <<'PY'
import importlib
import os
import torch, flashinfer, vllm
print("torch", torch.__version__, torch.version.cuda)
print("flashinfer", getattr(flashinfer, "__version__", "unknown"))
print("vllm", getattr(vllm, "__version__", "unknown"))
if os.environ.get("TRITON_KERNELS_REF"):
    importlib.import_module("vllm.third_party.triton_kernels.matmul_ogs")
PY

RUN launcher_root=/opt/vllm \
 && if [[ ! -f "${launcher_root}/scripts/run-glm51-vllm" && ! -f "${launcher_root}/serve-glm51.sh" ]]; then \
      git clone --filter=blob:none "${LAUNCHER_REPO}" /tmp/vllm-launchers; \
      cd /tmp/vllm-launchers; \
      git checkout "${LAUNCHER_REF}"; \
      if [[ -n "${LAUNCHER_COMMIT}" ]]; then test "$(git rev-parse HEAD)" = "${LAUNCHER_COMMIT}"; fi; \
      launcher_root=/tmp/vllm-launchers; \
      cd /opt/vllm; \
    fi \
 && for script in "${launcher_root}"/serve-*.sh; do \
      if [[ -f "${script}" ]]; then install -m 0755 "${script}" "/usr/local/bin/$(basename "${script}")"; fi; \
    done \
 && if [[ -f "${launcher_root}/scripts/run-glm51-vllm" ]]; then \
      install -m 0755 "${launcher_root}/scripts/run-glm51-vllm" /usr/local/bin/run-glm51-vllm; \
    elif [[ -f /usr/local/bin/serve-glm51.sh ]]; then \
      cp /usr/local/bin/serve-glm51.sh /usr/local/bin/run-glm51-vllm; \
      chmod 0755 /usr/local/bin/run-glm51-vllm; \
    else \
      printf '%s\n' '#!/usr/bin/env bash' 'echo "GLM launcher is not available in this vLLM ref" >&2' 'exit 2' > /usr/local/bin/run-glm51-vllm; \
      chmod 0755 /usr/local/bin/run-glm51-vllm; \
    fi \
 && if [[ -f "${launcher_root}/scripts/run-kimi26-vllm" ]]; then \
      install -m 0755 "${launcher_root}/scripts/run-kimi26-vllm" /usr/local/bin/run-kimi26-vllm; \
    elif [[ -f /usr/local/bin/serve-kimi26.sh ]]; then \
      cp /usr/local/bin/serve-kimi26.sh /usr/local/bin/run-kimi26-vllm; \
      chmod 0755 /usr/local/bin/run-kimi26-vllm; \
    else \
      printf '%s\n' '#!/usr/bin/env bash' 'echo "Kimi launcher is not available in this vLLM ref" >&2' 'exit 2' > /usr/local/bin/run-kimi26-vllm; \
      chmod 0755 /usr/local/bin/run-kimi26-vllm; \
    fi \
 && bash -n /usr/local/bin/run-glm51-vllm \
